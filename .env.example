# NOOR local environment example
# Runtime source modes: mock | local-cdn | cdn
# Default: mock mode uses bundled demo fallback data.
NEXT_PUBLIC_NOOR_DATA_MODE=mock

# Local CDN mode after running:
# pnpm content:prepare
# pnpm dev
# Then choose "Local CDN" from Settings, or set this default manually.
# NEXT_PUBLIC_NOOR_DATA_MODE=local-cdn
NEXT_PUBLIC_NOOR_LOCAL_CDN_BASE=http://localhost:3200/noor-cdn

# External CDN mode for future production hosting.
# Run pnpm cdn:pack, publish content-pipeline/publish/noor-cdn-gh-pages
# to a separate data repository, then choose ONE base family below.

# GitHub Pages example:
# NEXT_PUBLIC_NOOR_DATA_MODE=cdn
# NEXT_PUBLIC_NOOR_MANIFEST_CDN_BASE=https://effortedutech.github.io/noor-cdn/noor-cdn
# NEXT_PUBLIC_NOOR_QURAN_CDN_BASE=https://effortedutech.github.io/noor-cdn/noor-cdn
# NEXT_PUBLIC_NOOR_TAFSEER_CDN_BASE=https://effortedutech.github.io/noor-cdn/noor-cdn
# NEXT_PUBLIC_NOOR_HADITH_CDN_BASE=https://effortedutech.github.io/noor-cdn/noor-cdn

# jsDelivr example:
# NEXT_PUBLIC_NOOR_DATA_MODE=cdn
# NEXT_PUBLIC_NOOR_MANIFEST_CDN_BASE=https://cdn.jsdelivr.net/gh/EffortEdutech/noor-cdn@main/noor-cdn
# NEXT_PUBLIC_NOOR_QURAN_CDN_BASE=https://cdn.jsdelivr.net/gh/EffortEdutech/noor-cdn@main/noor-cdn
# NEXT_PUBLIC_NOOR_TAFSEER_CDN_BASE=https://cdn.jsdelivr.net/gh/EffortEdutech/noor-cdn@main/noor-cdn
# NEXT_PUBLIC_NOOR_HADITH_CDN_BASE=https://cdn.jsdelivr.net/gh/EffortEdutech/noor-cdn@main/noor-cdn

# Sprint 15 CDN smoke test helper.
# Local default target is content-pipeline/publish/noor-cdn-gh-pages/noor-cdn.
# You can override it for pnpm cdn:smoke:
# NOOR_CDN_SMOKE_BASE=https://effortedutech.github.io/noor-cdn/noor-cdn

# Sprint 16 CDN promotion handoff.
# Generate a copy-pasteable env file after the published URL passes smoke test:
# pnpm cdn:smoke https://effortedutech.github.io/noor-cdn/noor-cdn
# pnpm cdn:promote https://effortedutech.github.io/noor-cdn/noor-cdn
# Or set the default promotion target used by pnpm cdn:promote:
# NOOR_CDN_PROMOTION_BASE=https://effortedutech.github.io/noor-cdn/noor-cdn

# Sprint 27.9 staging CDN branch test
# Staging-only test URL. Do not use this as production main CDN.
# NEXT_PUBLIC_NOOR_DATA_MODE=cdn
# NEXT_PUBLIC_NOOR_MANIFEST_CDN_BASE=https://cdn.jsdelivr.net/gh/EffortEdutech/noor-cdn@staging-ilm-mate-v1/noor-cdn
# NEXT_PUBLIC_NOOR_QURAN_CDN_BASE=https://cdn.jsdelivr.net/gh/EffortEdutech/noor-cdn@staging-ilm-mate-v1/noor-cdn
# NEXT_PUBLIC_NOOR_TAFSEER_CDN_BASE=https://cdn.jsdelivr.net/gh/EffortEdutech/noor-cdn@staging-ilm-mate-v1/noor-cdn
# NEXT_PUBLIC_NOOR_HADITH_CDN_BASE=https://cdn.jsdelivr.net/gh/EffortEdutech/noor-cdn@staging-ilm-mate-v1/noor-cdn
# NOOR_STAGING_CDN_BASE=https://cdn.jsdelivr.net/gh/EffortEdutech/noor-cdn@staging-ilm-mate-v1/noor-cdn
