{
  "name": "noor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "build": "pnpm -C apps/web build",
    "start": "pnpm -C apps/web start",
    "typecheck": "pnpm -C apps/web typecheck",
    "check:pack": "node scripts/check-noor-pack.mjs",
    "check:content": "node scripts/check-noor-content.mjs",
    "check:release": "node scripts/check-noor-release.mjs",
    "check:runtime": "node scripts/check-noor-runtime.mjs",
    "check:cdn-publish": "node scripts/check-noor-cdn-publish.mjs",
    "check:cdn-smoke": "node scripts/smoke-noor-cdn.mjs",
    "check:cdn-promotion": "node scripts/check-noor-cdn-promotion.mjs",
    "check:source-audit": "node scripts/check-noor-source-audit.mjs",
    "check:roadmap": "node scripts/check-noor-roadmap.mjs",
    "content:validate": "node scripts/validate-noor-cdn.mjs",
    "content:prepare": "node scripts/prepare-noor-cdn.mjs",
    "cdn:pack": "node scripts/build-noor-cdn-publish-pack.mjs",
    "cdn:verify": "node scripts/verify-noor-cdn-publish-pack.mjs",
    "cdn:smoke": "node scripts/smoke-noor-cdn.mjs",
    "cdn:promote": "node scripts/promote-noor-cdn.mjs",
    "source:audit": "node scripts/audit-noor-sources.mjs",
    "source:gate": "node scripts/audit-noor-sources.mjs --require-production",
    "roadmap:status": "node scripts/generate-noor-roadmap.mjs",
    "release:bump": "node scripts/bump-noor-version.mjs"
  },
  "devDependencies": {
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4"
  }
}
