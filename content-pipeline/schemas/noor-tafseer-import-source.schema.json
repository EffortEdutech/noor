{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noor.local/schemas/noor-tafseer-import-source.schema.json",
  "title": "NOOR Tafseer Import Source",
  "type": "object",
  "required": [
    "id",
    "version",
    "adapter",
    "sourceCandidateId",
    "sourceLabel",
    "attributionText",
    "book",
    "entries"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "const": "0.22.0"
    },
    "adapter": {
      "const": "noor-tafseer-importer-v1"
    },
    "status": {
      "type": "string"
    },
    "sourceCandidateId": {
      "type": "string",
      "minLength": 1
    },
    "sourceLabel": {
      "type": "string",
      "minLength": 1
    },
    "licenseStatus": {
      "type": "string"
    },
    "productionApproved": {
      "type": "boolean"
    },
    "reviewerSignoff": {
      "type": "boolean"
    },
    "attributionText": {
      "type": "string",
      "minLength": 1
    },
    "book": {
      "type": "object",
      "required": [
        "bookId",
        "title",
        "language",
        "author",
        "description"
      ],
      "properties": {
        "bookId": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "translator": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "surah",
          "fromAyah",
          "toAyah",
          "title",
          "body"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "surah": {
            "type": "integer",
            "minimum": 1,
            "maximum": 114
          },
          "fromAyah": {
            "type": "integer",
            "minimum": 1
          },
          "toAyah": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
